    <diagram id="transformer-accel-arch" name="TinyLlama Decoder Layer Accelerator">
        <mxGraphModel dx="1674" dy="779" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1700" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="FPGA Accelerator — Xilinx Alveo U55C" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=top;spacingTop=8;fontSize=14;fontStyle=1;rounded=1;arcSize=3;" parent="1" vertex="1">
                    <mxGeometry x="10" y="20" width="1130" height="1650" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="&lt;b&gt;Shared Compute Resources&lt;/b&gt;&lt;hr/&gt;MAC Array (8 lanes Phase 1 · target ~512 · INT8×INT8→INT32) · Control FSM&lt;br&gt;Weights stream from HBM (8 GB) · Activations in on-chip BRAM · Accumulator Regs&lt;br&gt;&lt;i&gt;All green blocks time-multiplex on this engine · Owners: Rijul (MAC) · Samarth (FSM + buffers)&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="630" y="1440" width="480" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;b&gt;Layer Input X&lt;/b&gt;&lt;hr/&gt;Hidden state / first-layer embedding&lt;br&gt;[seq_len × d_model]&lt;br&gt;INT8 or requantized INT8" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="50" width="170" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;b&gt;Phase 1 System Split&lt;/b&gt;&lt;hr/&gt;Host CPU handles tokenization, embedding lookup, the 22-layer loop, final RMSNorm, LM head, and sampling.&lt;br&gt;The FPGA diagram below shows one reused TinyLlama decoder layer datapath." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="280" y="50" width="760" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="One TinyLlama Decoder Layer - On-Chip Dataflow (Host-orchestrated Phase 1) - Reused 22x by host loop" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=#999999;fontSize=12;fontStyle=1;fontColor=#666666;rounded=0;strokeWidth=1;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="170" width="970" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="&lt;b&gt;RMSNorm 1&lt;/b&gt; (pre-attention)&lt;hr/&gt;attn_input = x / sqrt(mean(x²) + eps) × weight&lt;br&gt;No mean subtraction · FP32 internal · INT8 out&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;NEW HARDWARE&lt;/b&gt;&lt;/font&gt; · &lt;i&gt;Owner: Rijul · Not Started&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="220" width="500" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="40" value="&lt;b&gt;Q Projection&lt;/b&gt;&lt;hr/&gt;attn_input × Wq → Q&lt;br&gt;[seq_len × d_model · 32 Q heads]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="345" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="41" value="&lt;b&gt;K Projection&lt;/b&gt;&lt;hr/&gt;attn_input × Wk → K&lt;br&gt;[seq_len × d_k · 4 KV heads]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="310" y="345" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="42" value="&lt;b&gt;V Projection&lt;/b&gt;&lt;hr/&gt;attn_input × Wv → V&lt;br&gt;[seq_len × d_v · 4 KV heads]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="560" y="345" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="&lt;b&gt;RoPE&lt;/b&gt; (Rotary Positional Embedding)&lt;hr/&gt;Q_rot = Q·cos + rotate_half(Q)·sin&lt;br&gt;K_rot = K·cos + rotate_half(K)·sin&lt;br&gt;sin/cos tables in BRAM · indexed by position · V unchanged&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;NEW HARDWARE&lt;/b&gt;&lt;/font&gt; · &lt;i&gt;Owner: Rijul · Not Started&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="460" width="440" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="43" value="&lt;b&gt;Attention Scores&lt;/b&gt;&lt;hr/&gt;Q_rot × K_rotᵀ / √d_k&lt;br&gt;[seq_len × seq_len]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="600" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="44" value="&lt;b&gt;Causal Mask + Softmax Unit&lt;/b&gt;&lt;hr/&gt;Apply causal mask, LUT-based exp(), running sum, normalize&lt;br&gt;For seq_len=1 this reduces to a trivial passthrough&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;NEW HARDWARE&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;i&gt;Owner: Rijul · In Progress&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="310" y="590" width="190" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="45" value="&lt;b&gt;Weighted Sum&lt;/b&gt;&lt;hr/&gt;softmax(…) × V&lt;br&gt;[seq_len × d_v]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="560" y="600" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="46" value="&lt;b&gt;Output Projection&lt;/b&gt;&lt;hr/&gt;attn_out × W_O&lt;br&gt;[seq_len × d_model]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="810" y="600" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="80" value="&lt;b&gt;Residual Add 1&lt;/b&gt;&lt;hr/&gt;X + W_O_out&lt;br&gt;(elementwise add)&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;NEW HARDWARE&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;i&gt;Owner: Samarth&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="730" width="190" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="31" value="SwiGLU FFN Block" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=#999999;fontSize=11;fontStyle=3;fontColor=#666666;rounded=0;strokeWidth=1;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="865" width="970" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="85" value="&lt;b&gt;RMSNorm 2&lt;/b&gt; (pre-FFN)&lt;hr/&gt;ffn_input = x / sqrt(mean(x²) + eps) × weight&lt;br&gt;No mean subtraction · FP32 internal · INT8 out&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;NEW HARDWARE&lt;/b&gt;&lt;/font&gt; · &lt;i&gt;Owner: Rijul · Not Started&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="900" width="500" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="86" value="&lt;b&gt;gate_proj&lt;/b&gt;&lt;hr/&gt;ffn_input × W_gate → gate&lt;br&gt;[seq_len × d_ff · d_ff=5632]&lt;br&gt;&lt;i&gt;Uses MAC array&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1025" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="87" value="&lt;b&gt;up_proj&lt;/b&gt;&lt;hr/&gt;ffn_input × W_up → up&lt;br&gt;[seq_len × d_ff · d_ff=5632]&lt;br&gt;&lt;i&gt;Uses MAC array (parallel)&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="310" y="1025" width="190" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="88" value="&lt;b&gt;SiLU + Elementwise Multiply&lt;/b&gt; (SwiGLU)&lt;hr/&gt;hidden = SiLU(gate) × up&lt;br&gt;SiLU(x) = x / (1 + exp(-x)) · LUT-based exp&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;NEW HARDWARE&lt;/b&gt;&lt;/font&gt; · &lt;i&gt;Owner: Rijul · Not Started&lt;/i&gt;" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" parent="1" vertex="1">
