<mxfile host="65bd71144e">
    <diagram id="tinyllama-u55c-post-phase1" name="TinyLlama U55C Accelerator">
        <mxGraphModel dx="1674" dy="779" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1250" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="TinyLlama U55C Accelerator - Post-Phase-1 Architecture" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="420" y="20" width="900" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="&lt;b&gt;Host CPU / XRT&lt;/b&gt;&lt;hr/&gt;Tokenize prompt&lt;br/&gt;Upload prompt token ids and generation parameters&lt;br/&gt;Receive generated token ids and debug dumps&lt;br/&gt;Detokenize for display" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="40" y="170" width="240" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="FPGA Accelerator - Xilinx Alveo U55C" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=top;spacingTop=8;fontSize=14;fontStyle=1;rounded=1;arcSize=4;" parent="1" vertex="1">
                    <mxGeometry x="310" y="90" width="1430" height="1060" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;b&gt;Post-Phase-1 Control Split&lt;/b&gt;&lt;hr/&gt;The FPGA owns prefill scheduling, decode-step control, 22-layer iteration, KV-cache management, final RMSNorm, LM head, greedy argmax, and stop-condition handling." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="350" y="120" width="1350" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;b&gt;On-chip Prefill / Decode Controller&lt;/b&gt;&lt;hr/&gt;Prefill: process the full prompt and populate KV cache&lt;br/&gt;Decode: process one token, append new K/V, emit next token&lt;br/&gt;Iterates layer_idx = 0..21&lt;br/&gt;Stops on EOS or max_new_tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="380" y="240" width="420" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="&lt;b&gt;Embedding Lookup&lt;/b&gt;&lt;hr/&gt;Token ids + positions -&gt; first activation sequence / decode token vector&lt;br/&gt;Embedding table lives in HBM&lt;br/&gt;Output path is quantized into the decoder datapath" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="380" y="440" width="300" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="&lt;b&gt;One Reused TinyLlama Decoder-Layer Engine&lt;/b&gt;&lt;hr/&gt;Same tensor sizes and block structure for all 22 layers&lt;br/&gt;Reused for layer_idx = 0..21&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Layer flow&lt;/b&gt;&lt;br/&gt;1. RMSNorm 1&lt;br/&gt;2. Q / K / V projections + RoPE&lt;br/&gt;3. Attention scores + causal mask + softmax&lt;br/&gt;4. Weighted sum with V + O projection&lt;br/&gt;5. Residual add&lt;br/&gt;6. RMSNorm 2&lt;br/&gt;7. gate / up projections&lt;br/&gt;8. SiLU * up + down projection&lt;br/&gt;9. Residual add" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="730" y="390" width="500" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="&lt;b&gt;HBM Weight + KV Store&lt;/b&gt;&lt;hr/&gt;16 GB HBM / 32 pseudo-channels&lt;br/&gt;Embedding weights&lt;br/&gt;22 layers of weights + RMSNorm gamma vectors&lt;br/&gt;Final RMSNorm + LM head weights&lt;br/&gt;Per-layer K cache and V cache&lt;br/&gt;Quantization scales / metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="260" width="390" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="&lt;b&gt;Final RMSNorm + LM Head + Token Select&lt;/b&gt;&lt;hr/&gt;Apply final RMSNorm&lt;br/&gt;Run tiled LM head projection&lt;br/&gt;Greedy argmax emits the next token id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="540" width="390" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="&lt;b&gt;Shared INT8 GEMM Engine&lt;/b&gt;&lt;hr/&gt;Reused for Q, K, V, attention scores, weighted sum, O, gate, up, down, and LM head&lt;br/&gt;INT8 inputs / INT8 weights / INT32 accumulation&lt;br/&gt;One engine reused across all layer GEMMs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="380" y="800" width="580" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="&lt;b&gt;Higher-Precision Math Blocks&lt;/b&gt;&lt;hr/&gt;RMSNorm, RoPE, softmax, and residual path control&lt;br/&gt;Higher precision is retained where pure INT8 is too fragile&lt;br/&gt;Residual accumulation stays INT32 before requantization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="800" width="660" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="&lt;b&gt;22-Layer Reuse Model&lt;/b&gt;&lt;hr/&gt;All 22 TinyLlama layers use hidden_size = 2048, intermediate_size = 5632, head_dim = 64, 32 Q heads, and 4 KV heads.&lt;br/&gt;The same decoder-layer engine is reused every layer; only the weights, RMSNorm gamma vectors, and KV-cache region change.&lt;br/&gt;Prefill writes KV rows for every prompt token; decode reads cached K/V and appends one new row per layer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="380" y="980" width="1290" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="100" value="prompt token ids / params / launch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;strokeWidth=2;" parent="1" source="3" target="6" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
